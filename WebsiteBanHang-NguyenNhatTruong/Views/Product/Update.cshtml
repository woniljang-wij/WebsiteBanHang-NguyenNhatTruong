@model WebsiteBanHang_NguyenNhatTruong.Models.Product

@{
    ViewData["Title"] = "Cập nhật sản phẩm";
}

<div class="container mt-4">

    <h2 class="mb-4">✏️ Cập nhật sản phẩm</h2>

    <div class="card shadow-sm p-4">

        <form asp-action="Update" enctype="multipart/form-data">

            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label class="form-label">Tên sản phẩm</label>
                <input asp-for="Name" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Giá (VNĐ)</label>
                <input asp-for="Price" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Mô tả sản phẩm</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            </div>

            <div class="mb-3">
                <label class="form-label">Danh mục</label>

                <select asp-for="CategoryId"
                        asp-items="ViewBag.Categories"
                        class="form-control">
                </select>

            </div>

            <div class="mb-3">

                <label class="form-label">Hình ảnh hiện tại</label>

                <div class="text-center">

                    <img src="@Model.ImageUrl"
                         class="product-img rounded" />

                </div>

            </div>

            <div class="mb-3">

                <label class="form-label">Chọn ảnh mới</label>

                <input type="file"
                       name="imageUrl"
                       class="form-control"
                       onchange="previewImage(event)" />

            </div>

            <div class="mb-3 text-center">

                <img id="preview"
                     style="max-height:200px; display:none; border-radius:10px;" />

            </div>

            <div class="d-flex gap-2">

                <button class="btn btn-primary">
                    💾 Cập nhật
                </button>

                <a asp-action="Index"
                   class="btn btn-secondary">
                    ← Quay lại
                </a>

            </div>

        </form>

    </div>

</div>


<style>

    .product-img {
        width: 100%;
        max-height: 250px;
        object-fit: contain;
        background: white;
        padding: 10px;
    }

</style>


<script>

    function previewImage(event) {

        const reader = new FileReader();

        reader.onload = function () {

            const img = document.getElementById("preview");
            img.src = reader.result;
            img.style.display = "block";

        }

        reader.readAsDataURL(event.target.files[0]);
    }

</script>