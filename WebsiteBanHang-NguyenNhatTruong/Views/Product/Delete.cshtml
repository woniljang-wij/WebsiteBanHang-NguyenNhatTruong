@using WebsiteBanHang_NguyenNhatTruong.Helpers
@model WebsiteBanHang_NguyenNhatTruong.Models.Product

@{
    ViewData["Title"] = "Xóa sản phẩm";
}

<div class="container mt-4">

    <h2 class="text-danger mb-4">🗑 Xóa sản phẩm</h2>

    <div class="card shadow-sm p-4">

        <h4 class="mb-3">
            Bạn có chắc muốn xóa sản phẩm này không?
        </h4>

        <hr />

        <div class="row">

            <div class="col-md-4 text-center">

                <img src="@Model.ImageUrl"
                     class="product-img rounded" />

            </div>

            <div class="col-md-8">

                <p>
                    <strong>Tên sản phẩm:</strong>
                    @Model.Name
                </p>

                <p>
                    <strong>Giá:</strong>
                    <span class="text-danger">
                        @CurrencyHelper.ToVnd(Model.Price)
                    </span>
                </p>

                <p>
                    <strong>Danh mục:</strong>
                    @Model.Category?.Name
                </p>

                <div class="mt-4 d-flex gap-2">

                    <form asp-action="Delete">

                        <input type="hidden" asp-for="Id" />

                        <button class="btn btn-danger">
                            🗑 Xóa
                        </button>

                    </form>

                    <a asp-action="Index"
                       class="btn btn-secondary">
                        ← Hủy
                    </a>

                </div>

            </div>

        </div>

    </div>

</div>

<style>

    .product-img {
        width: 100%;
        max-height: 200px;
        object-fit: contain;
        background: white;
        padding: 10px;
    }

</style>