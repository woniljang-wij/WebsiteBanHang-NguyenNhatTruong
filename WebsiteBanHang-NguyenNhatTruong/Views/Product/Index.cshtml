@using WebsiteBanHang_NguyenNhatTruong.Helpers
@model IEnumerable<WebsiteBanHang_NguyenNhatTruong.Models.Product>

@{
    ViewData["Title"] = "Cửa hàng sản phẩm";
}

<div class="container mt-4">

    <div class="d-flex justify-content-end mb-4">

        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Add" class="btn-add-product">
                + Thêm sản phẩm
            </a>
        }

    </div>

    <div class="row">

        @foreach (var item in Model)
        {
            <div class="col-md-3 mb-4">

                <div class="card product-card h-100">

                    <div class="product-img-box">

                        <img src="@item.ImageUrl"
                             class="card-img-top product-img" />

                        @* BADGE TÌNH TRẠNG *@
                        @if (item.Quantity == 0)
                        {
                            <span class="badge-out">HẾT HÀNG</span>
                        }
                        else if (item.Quantity < 5)
                        {
                            <span class="badge-low">SẮP HẾT</span>
                        }

                    </div>

                    <div class="card-body">

                        <h5 class="product-title">
                            @item.Name
                        </h5>

                        <h5 class="product-price">
                            @CurrencyHelper.ToVnd(item.Price)
                        </h5>

                        <p class="product-quantity">
                            Số lượng: @item.Quantity
                        </p>

                        <p class="product-category">
                            Danh mục: @item.Category?.Name
                        </p>

                        <div class="d-flex gap-2 mt-3">

                            <a asp-action="Display"
                               asp-route-id="@item.Id"
                               class="btn btn-outline-primary btn-sm">
                                👁 Xem
                            </a>

                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-action="Update"
                                   asp-route-id="@item.Id"
                                   class="btn btn-warning btn-sm">
                                    ✏ Sửa
                                </a>

                                <a asp-action="Delete"
                                   asp-route-id="@item.Id"
                                   class="btn btn-danger btn-sm">
                                    🗑 Xóa
                                </a>
                            }

                        </div>

                    </div>

                </div>

            </div>
        }

    </div>

</div>