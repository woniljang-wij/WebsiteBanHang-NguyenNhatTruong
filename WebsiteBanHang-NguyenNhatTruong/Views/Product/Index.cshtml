@using WebsiteBanHang_NguyenNhatTruong.Helpers
@model IEnumerable<WebsiteBanHang_NguyenNhatTruong.Models.Product>

@{
    ViewData["Title"] = "Cửa hàng sản phẩm";
}

<div class="container mt-4">

    <div class="d-flex justify-content-end mb-4">

        <a asp-action="Add" class="btn-add-product">
            + Thêm sản phẩm
        </a>

    </div>

    <div class="row">

        @foreach (var item in Model)
        {
            <div class="col-md-3 mb-4">

                <div class="card shadow-sm h-100 product-card">

                    <img src="@item.ImageUrl"
                         class="card-img-top product-img" />

                    <div class="card-body">

                        <h5 class="card-title product-title">
                            @item.Name
                        </h5>

                        <h6 class="text-danger">

                            @CurrencyHelper.ToVnd(item.Price)

                        </h6>

                        <p class="text-muted">

                            Danh mục: @item.Category?.Name

                        </p>

                        <div class="d-flex gap-2">

                            <a asp-action="Display"
                               asp-route-id="@item.Id"
                               class="btn btn-outline-primary btn-sm">
                                Xem
                            </a>

                            <a asp-action="Update"
                               asp-route-id="@item.Id"
                               class="btn btn-warning btn-sm">
                                Sửa
                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@item.Id"
                               class="btn btn-danger btn-sm">
                                Xóa
                            </a>

                        </div>

                    </div>

                </div>

            </div>
        }

    </div>

</div>


<style>

    .product-img {
        height: 200px;
        width: 100%;
        object-fit: contain;
        background: #f5f5f5;
    }

</style>