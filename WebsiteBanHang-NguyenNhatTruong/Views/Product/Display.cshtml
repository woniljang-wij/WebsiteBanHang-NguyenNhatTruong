@using WebsiteBanHang_NguyenNhatTruong.Helpers
@model WebsiteBanHang_NguyenNhatTruong.Models.Product

@{
    ViewData["Title"] = "Chi tiết sản phẩm";
}

<div class="container mt-4">

    <div class="card shadow-sm p-4">

        <div class="row">

            <div class="col-md-5 text-center">

                <img src="@Model.ImageUrl"
                     class="product-img rounded" />

            </div>

            <div class="col-md-7">

                <h2 class="mb-3">
                    @Model.Name
                </h2>

                <h3 class="text-danger mb-3">
                    @CurrencyHelper.ToVnd(Model.Price)
                </h3>

                <p class="text-muted">
                    <strong>Danh mục:</strong>
                    @Model.Category?.Name
                </p>

                <hr />

                <p>
                    @Model.Description
                </p>

                <div class="mt-4 d-flex gap-2">

                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Update" asp-route-id="@Model.Id" class="btn btn-warning">
                            ✏ Sửa
                        </a>
                    }

                    <a asp-action="Index"
                       class="btn btn-secondary">
                        ← Quay lại
                    </a>

                </div>

            </div>

        </div>

    </div>

</div>


<style>

    .product-img {
        width: 100%;
        height: 350px;
        object-fit: contain;
        background: white;
        padding: 10px;
    }

</style>